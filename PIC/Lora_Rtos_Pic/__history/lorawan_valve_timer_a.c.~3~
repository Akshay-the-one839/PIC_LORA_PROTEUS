// Function to initialize Timer1 for a 1-second interrupt
void setup_timer1_for_1s_interrupt() {
    setup_timer_1(T1_INTERNAL | T1_DIV_BY_8);
    set_timer1(34286);  // 1-second interval
    enable_interrupts(INT_TIMER1);  // Enable Timer1 interrupt
    
}  

#INT_TIMER1
void timer1_isr() {

      overflow_count++;  // Increment overflow count

      set_timer1(34286);
      
   if (overflow_count >= 20) {        //  for 1-second delay 
            sec++;
        overflow_count = 0;  // Reset overflow count
      
        if(sec >= 59){
        
        // output_low(DRYLED );//l1 off 
   
        sec=0;
        min++;
        bwminv1++ ;
        if(bwminv1 >=11)
        {
         bwminv1=0;
        }
         bwminv2++ ;
        if(bwminv2 >=11)
        {
         bwminv2=0;
        }
        // retrive the hours and minutes before start the timer
      write_eeprom(eeprom_base_address + 40, hr); // to read previous hr stored 
      write_eeprom(eeprom_base_address + 41, min); // to read previous min stored

        if(min >= 59){
        min=0;
        hr++;

        }
        
        if(hr >= 24){
        
        hr=0;
        
        }
        
        }
            
    }
    
}

// Function to store a single byte value in EEPROM
void store_byte(unsigned int16 address, unsigned char value) {
    if (address < 256) { // Ensure address is within EEPROM range
        write_eeprom(address, value);
    }
}

// Function to retrieve a single byte value from EEPROM
unsigned char retrieve_byte(unsigned int16 address) {
    if (address < 256) { // Ensure address is within EEPROM range
        return read_eeprom(address);
    }
    return 0; // Default value in case of invalid address
}

#int_RDA
void RDA_isr(void)
{
    char temp; 
    char temp3;

    // ---------- 1) UART ERROR CHECK (hardware flags) ----------
    // Handle Overrun: must reset CREN to recover receiver hardware.
    if (oerr) {           // Overrun error (CCS alias for OERR)
        CREN = 0;         // disable receiver to clear overrun condition
        CREN = 1;         // re-enable receiver
        return;           // discard and skip processing damaged data
    }
    // Handle Framing error: discard the problematic byte and continue
    if (ferr) {
        char tmp = getc(COM_1); // read and drop one byte from FIFO
        return;
